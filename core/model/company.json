{
  "name": "Market Catalyst Core Model",
  "version": "26.02.27.1",
  "author": "Market Catalyst",
  "description": "Market Catalyst core model: reusable trust primitives shared across market types.",
  "include_x_fields": true,
  "entities": [
    {
      "name": "company",
      "brief": "Company or organization entity",
      "description": "Generic company or organization entity that can be used across different\nmarket types. This is a core entity that provides basic company information\nwithout market-specific relationships.\n",
      "primary_key": "company_id",
      "fields": [
        {
          "name": "company_id",
          "type": {
            "primitive": "string"
          },
          "required": true,
          "description": "Unique company identifier (e.g., domain name, organization ID)"
        },
        {
          "name": "company_name",
          "type": {
            "primitive": "string"
          },
          "required": true,
          "description": "Official company name"
        },
        {
          "name": "domain",
          "type": {
            "primitive": "string"
          },
          "required": false,
          "description": "Company website domain (e.g., 'acme.com')"
        },
        {
          "name": "industry",
          "type": {
            "primitive": "string"
          },
          "required": false,
          "description": "Industry sector (e.g., 'Technology', 'Finance', 'Healthcare')"
        },
        {
          "name": "location",
          "type": {
            "primitive": "string"
          },
          "required": false,
          "description": "Primary location or headquarters"
        },
        {
          "name": "job_postings",
          "type": {
            "array": {
              "entity": "job_posting"
            }
          },
          "required": false,
          "description": "Job postings for this company (nested children)"
        },
        {
          "name": "reviews",
          "type": {
            "array": {
              "entity": "review"
            }
          },
          "required": false,
          "description": "Reviews for this company (nested children)"
        }
      ]
    }
  ]
}
